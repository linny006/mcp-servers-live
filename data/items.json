      "claude_config": "{\n  \"mcpServers\": {\n    \"github-mcp\": {\n      \"command\": \"uvx\",\n      \"args\": [\n        \"--from\",\n        \"github-agent[mcp]\",\n        \"github-mcp\"\n      ],\n      \"env\": {\n        \"MCP_TOOL_MODE\": \"condensed\",\n        \"ACTIONTOOL\": \"True\",\n        \"BRANCHTOOL\": \"True\",\n        \"COLLABORATORTOOL\": \"True\",\n        \"COMMITTOOL\": \"True\",\n        \"CONTENTTOOL\": \"True\",\n        \"DEPENDABOTTOOL\": \"True\",\n        \"GITHUB_ALLOW_DESTRUCTIVE\": \"False\",\n        \"GITHUB_HTTP_CONNECT_TIMEOUT\": \"10\",\n        \"GITHUB_HTTP_READ_TIMEOUT\": \"30\",\n        \"GITHUB_TOKEN\": \"your_github_token_here\",\n        \"GITHUB_URL\": \"https://api.github.com\",\n        \"GITHUB_VERIFY\": \"True\",\n        \"GRAPHQLTOOL\": \"True\",\n        \"INGESTTOOL\": \"True\",\n        \"ISSUETOOL\": \"True\",\n        \"ORGTOOL\": \"True\",\n        \"PULLTOOL\": \"True\",\n        \"RELEASETOOL\": \"True\",\n        \"REPOTOOL\": \"True\",\n        \"SEARCHTOOL\": \"True\"\n      }\n    }\n  }\n}",
      "install_cmd": "docker run -d \\",
      "install_kind": "docker run"
    },
