    "install_info": {
      "claude_config": "{\n  \"mcpServers\": {\n    \"knowledge-gun\": {\n      \"command\": \"knowledge-gun-mcp\",\n      \"env\": {\n        \"KNOWLEDGE_GUN_GRAPH_PATH\": \"/Users/<you>/path/to/your/graph.json\",\n        \"KNOWLEDGE_GUN_INTRO_DIR\": \"/Users/<you>/path/to/intros/\",\n        \"KNOWLEDGE_GUN_ROOTS_DIR\": \"/Users/<you>/path/to/roots/\"\n      }\n    }\n  }\n}",
